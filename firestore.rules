rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() {
      return request.auth != null;
    }

    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Entity Validations
    function isValidUser(data) {
      return data.userId == request.auth.uid 
        && data.email is string && data.email.size() <= 100
        && (data.displayName == null || (data.displayName is string && data.displayName.size() <= 100))
        && (data.photoURL == null || (data.photoURL is string && data.photoURL.size() <= 500))
        && (data.hasSeenTutorial == null || data.hasSeenTutorial is bool);
    }

    function isValidReport(data) {
      return data.userId == request.auth.uid
        && data.reportId is string && data.reportId.size() <= 128
        && data.createdAt == request.time
        && data.tension is number
        && data.steps is list && data.steps.size() <= 100
        && data.parameters is map;
    }

    function isValidChallenge(data) {
      return data.title is string && data.title.size() <= 200
        && data.description is string && data.description.size() <= 1000
        && data.params is map
        && data.params.keys().hasAll(['loadA', 'leverLength', 'pulleyRadius', 'distBC', 'distCD', 'distDE'])
        && data.params.keys().size() == 6
        && data.solved is bool
        && data.createdAt == request.time;
    }

    // 1. Users Collection
    match /users/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidUser(incoming()) && (
        incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'photoURL', 'lastSeen', 'hasSeenTutorial'])
      );

      // 1.1 Challenges Subcollection
      match /challenges/{challengeId} {
        allow list, get: if isOwner(userId);
        allow create: if isOwner(userId) && isValidChallenge(incoming());
        allow update: if isOwner(userId) && (
          // Allow marking as solved
          (incoming().diff(existing()).affectedKeys().hasOnly(['solved', 'solvedAt']) && incoming().solved == true)
        );
        allow delete: if isOwner(userId);
      }
    }

    // 2. Reports Collection
    match /reports/{reportId} {
      allow get: if isSignedIn() && existing().userId == request.auth.uid;
      allow list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isValidId(reportId) && isValidReport(incoming());
      // Reports are immutable by users
      allow update, delete: if false;
    }
  }
}
